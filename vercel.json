{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_REF\" != \"main\" ]",
  "regions": ["sfo1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/comms/messages/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/bom/extract/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/webhooks/hubspot/design-complete/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/webhooks/hubspot/ready-to-build/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/zuper/jobs/schedule/confirm/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/daily-focus/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/eod-summary/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/zuper/sync-cache/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/deal-sync/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/webhooks/hubspot/deal-sync/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/product-sync/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/inventory/product-sync/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/webhooks/hubspot/property/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/property-reconcile/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/office-performance-warm/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/powerhub-assets/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/powerhub-telemetry/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/powerhub-alerts/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/enphase-assets/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/enphase-telemetry/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/enphase-status-check/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/goals-digest/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/pe-invoice-audit/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/pe-email-sync/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/pe-api-sync/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/shovels-enrich/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/zuper-property-sync/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/zuper-job-backfill/route.ts": { "maxDuration": 120 }
  },
  "crons": [
    {
      "path": "/api/cron/shit-show-task-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/updates/notify",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/cron/admin-workflow-cleanup",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/admin-workflow-cron-dispatch",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/audit-digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/audit-retention",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/permit-hub-drafts-cleanup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/solar/cron/cleanup-pending",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/catalog/vendors/sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/pipeline-health",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/daily-focus",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/zuper/sync-cache",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/eod-summary",
      "schedule": "0 23 * * 1-5"
    },
    {
      "path": "/api/cron/deal-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/product-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/property-reconcile",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/estimator-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/estimator-hubspot-reconcile",
      "schedule": "*/20 * * * *"
    },
    {
      "path": "/api/cron/adders-sync",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/compliance-shadow-cleanup",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/eagleview-poll-orders",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/pm-snapshot",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/pm-weekly-digest",
      "schedule": "0 14 * * 1"
    },
    {
      "path": "/api/cron/pm-flag-rules",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/aircall-sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/pandadoc-da-reconcile",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/zuper-status-reconcile",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/office-performance-warm",
      "schedule": "*/4 * * * *"
    },
    { "path": "/api/cron/powerhub-assets", "schedule": "0 0,6,12,18 * * *" },
    { "path": "/api/cron/powerhub-telemetry", "schedule": "2,17,32,47 * * * *" },
    { "path": "/api/cron/powerhub-alerts", "schedule": "4,9,14,19,24,29,34,39,44,49,54,59 * * * *" },
    { "path": "/api/cron/enphase-assets", "schedule": "0 9 * * *" },
    { "path": "/api/cron/enphase-telemetry", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/enphase-status-check", "schedule": "5,35 * * * *" },
    { "path": "/api/cron/goals-digest", "schedule": "0 14 * * 1,2" },
    { "path": "/api/cron/pe-invoice-audit", "schedule": "7 * * * *" },
    { "path": "/api/cron/pe-email-sync", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/pe-api-sync", "schedule": "0 0-1,13-23 * * *" },
    { "path": "/api/cron/pe-doc-digest", "schedule": "30 21 * * 1-5" },
    { "path": "/api/cron/shovels-enrich", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/zuper-property-sync", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/zuper-job-backfill", "schedule": "0 * * * *" }
  ],
  "redirects": [
    {
      "source": "/dashboards/_archive/:path*",
      "destination": "/404",
      "permanent": false
    },
    {
      "source": "/prototypes/:path*.html",
      "destination": "/404",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/dashboards/:path*",
      "destination": "/dashboards/:path*"
    }
  ]
}
