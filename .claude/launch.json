{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Email Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["react-email", "dev", "--dir", "src/emails"],
      "port": 3001
    },
    {
      "name": "Digest Static Preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "8799", "public"],
      "port": 8799
    }
  ]
}
