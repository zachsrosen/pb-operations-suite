// ---------------------------------------------------------------------------
// IDR Meeting Hub
// ---------------------------------------------------------------------------

enum IdrSessionStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum IdrItemType {
  IDR
  ESCALATION
}

enum IdrSyncStatus {
  DRAFT
  SYNCED
  FAILED
}

enum IdrThreadPostStatus {
  PENDING
  POSTED
  FAILED
  SKIPPED
}

model IdrMeetingSession {
  id        String           @id @default(cuid())
  date      DateTime
  status    IdrSessionStatus @default(DRAFT)
  source    String?          // "app" or "google-doc-import"
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  items IdrMeetingItem[]

  @@index([date])
}

model IdrMeetingItem {
  id        String      @id @default(cuid())
  sessionId String
  session   IdrMeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dealId    String
  type      IdrItemType @default(IDR)
  region    String      // pb_location
  sortOrder Int         @default(0)

  // Snapshot fields (refreshed via stale-while-revalidate)
  dealName         String
  address          String?
  projectType      String?
  equipmentSummary String?
  systemSizeKw     Float?
  dealAmount       Float?
  dealOwner         String?
  siteSurveyor      String?
  projectManager    String?
  operationsManager String?
  surveyStatus      String?
  surveyDate       String?
  designStatus     String?
  plansetDate      String?
  driveFolderUrl   String?
  surveyFolderUrl  String?
  designFolderUrl  String?
  ahj              String?
  utilityCompany   String?
  openSolarUrl     String?
  surveyCompleted  Boolean  @default(false)
  tags             String[] @default([])
  // Read-only HubSpot notes (snapshot)
  salesNotes              String?
  salesChangeOrderNotes   String?
  salesChangeOrderNeeded  Boolean  @default(false)
  notesForDesign          String?
  specificNotesForDesign  String?
  snapshotUpdatedAt DateTime @default(now())

  // Editable fields
  difficulty       Int?
  installerCount   Int?
  installerDays    Int?
  electricianCount Int?
  electricianDays  Int?
  discoReco        Boolean?
  interiorAccess   Boolean?
  needsSurveyInfo       Boolean?  // Flag: needs info from site surveyor → DA status "Pending Ops Changes"
  needsResurvey         Boolean?  // Flag: requires resurvey → DA status "Pending Resurvey"
  salesChangeRequested  Boolean?  // Flag: trigger sales change → DA status "Pending Sales Changes"
  salesChangeNotes      String?   // Reason for sales change → HubSpot sales_communication_reason
  opsChangeNotes        String?   // Reason for ops/survey change → HubSpot ops_communication_reason
  customerNotes    String?
  operationsNotes  String?
  designNotes      String?
  conclusion       String?

  // Escalation
  escalationReason String?

  // Reviewed — marks that the team has finished reviewing this item in the meeting
  reviewed         Boolean  @default(false)

  // Shit Show flag — flagged for discussion in a shit show meeting
  shitShowFlagged  Boolean  @default(false)
  shitShowReason   String?

  // Sync status
  hubspotSyncStatus IdrSyncStatus       @default(DRAFT)
  hubspotSyncedAt   DateTime?
  threadPostStatus  IdrThreadPostStatus  @default(SKIPPED)

  addedBy   String    // "system" or user email
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  notes IdrMeetingNote[]

  @@unique([sessionId, dealId])
  @@index([sessionId, region])
  @@index([dealId])
}

model IdrMeetingNote {
  id        String   @id @default(cuid())
  itemId    String
  item      IdrMeetingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  dealId    String   // denormalized for cross-meeting queries
  content   String
  author    String
  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([dealId, createdAt])
}

/// Meeting prep queue — escalations + preview field edits for the next session.
/// ESCALATION = deal added to sidebar for discussion.
/// PREP = field edits saved on preview items (merged into session on start).
/// When a session is created, all QUEUED items are consumed.
model IdrEscalationQueue {
  id               String   @id @default(cuid())
  dealId           String
  dealName         String   // snapshot for display without HubSpot fetch
  region           String?
  queueType        String   @default("ESCALATION") // ESCALATION | PREP
  reason           String   @default("") // escalation reason (empty for PREP)
  status           IdrEscalationStatus @default(QUEUED)
  requestedBy      String   // user email
  consumedBySession String?  // session ID that consumed this item

  // Prefilled fields — carried into the session item on consume
  difficulty           Int?
  installerCount       Int?
  installerDays        Int?
  electricianCount     Int?
  electricianDays      Int?
  discoReco            Boolean?
  interiorAccess       Boolean?
  needsSurveyInfo      Boolean?
  needsResurvey        Boolean?
  salesChangeRequested Boolean?
  salesChangeNotes     String?
  opsChangeNotes       String?
  customerNotes        String?
  operationsNotes      String?
  designNotes          String?
  conclusion           String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([dealId])
}

enum IdrEscalationStatus {
  QUEUED
  CONSUMED
  DISMISSED
}

