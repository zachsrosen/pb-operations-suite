  hubspotSyncStatus IdrSyncStatus       @default(DRAFT)
  hubspotSyncedAt   DateTime?
  threadPostStatus  IdrThreadPostStatus @default(SKIPPED)

  addedBy   String // "system" or user email
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes IdrMeetingNote[]

  @@unique([sessionId, dealId])
  @@index([sessionId, region])
  @@index([dealId])
}

model IdrMeetingNote {
  id        String         @id @default(cuid())
  itemId    String
  item      IdrMeetingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  dealId    String // denormalized for cross-meeting queries
  content   String
  author    String
  createdAt DateTime       @default(now())

  @@index([itemId])
  @@index([dealId, createdAt])
}

/// Meeting prep queue — escalations + preview field edits for the next session.
/// ESCALATION = deal added to sidebar for discussion.
/// PREP = field edits saved on preview items (merged into session on start).
/// When a session is created, all QUEUED items are consumed.
model IdrEscalationQueue {
  id                String              @id @default(cuid())
  dealId            String
  dealName          String // snapshot for display without HubSpot fetch
  region            String?
  queueType         String              @default("ESCALATION") // ESCALATION | PREP
  reason            String              @default("") // escalation reason (empty for PREP)
  status            IdrEscalationStatus @default(QUEUED)
  requestedBy       String // user email
  consumedBySession String? // session ID that consumed this item

  // Prefilled fields — carried into the session item on consume
  difficulty              Int?
  installerCount          Int?
  installerDays           Int?
  electricianCount        Int?
  electricianDays         Int?
  discoReco               Boolean?
  interiorAccess          Boolean?
  needsSurveyInfo         Boolean?
  needsResurvey           Boolean? // Deprecated — retained for historical queue rows
  salesChangeRequested    Boolean?
  salesChangeNotes        String?
  opsChangeNotes          String?
  customerNotes           String?
  customerNotesCreateTask Boolean  @default(false)
  operationsNotes         String?
  designNotes             String?
  conclusion              String?

  // Adder checkboxes (carried over from prep/skip)
  adderTileRoof     Boolean @default(false)
  adderMetalRoof    Boolean @default(false)
  adderFlatFoamRoof Boolean @default(false)
  adderShakeRoof    Boolean @default(false)
  adderSteepPitch   Boolean @default(false)
  adderTwoStorey    Boolean @default(false)
  adderTrenching    Boolean @default(false)
  adderGroundMount  Boolean @default(false)
  adderMpuUpgrade   Boolean @default(false)
  adderEvCharger    Boolean @default(false)
  customAdders      Json    @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([dealId])
}

enum IdrEscalationStatus {
  QUEUED
  CONSUMED
  DISMISSED
}

