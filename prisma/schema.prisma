  items IdrMeetingItem[]

  @@index([date])
}

model IdrMeetingItem {
  id        String            @id @default(cuid())
  sessionId String
  session   IdrMeetingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dealId    String
  type      IdrItemType       @default(IDR)
  region    String // pb_location
  sortOrder Int               @default(0)

  // Snapshot fields (refreshed via stale-while-revalidate)
  dealName               String
  address                String?
  projectType            String?
  equipmentSummary       String?
  systemSizeKw           Float?
  dealAmount             Float?
  dealOwner              String?
  siteSurveyor           String?
  projectManager         String?
  operationsManager      String?
  surveyStatus           String?
  surveyDate             String?
  designStatus           String?
  designApprovalStatus   String? // HubSpot `layout_status` — DA workflow state
  plansetDate            String?
  driveFolderUrl         String?
  surveyFolderUrl        String?
  designFolderUrl        String?
  ahj                    String?
  utilityCompany         String?
  openSolarUrl           String?
  salesFolderUrl         String? // HubSpot `sales_documents` — Drive folder link
  surveyCompleted        Boolean  @default(false)
  tags                   String[] @default([])
  // Read-only HubSpot notes (snapshot)
  salesNotes             String?
  salesChangeOrderNotes  String?
  salesChangeOrderNeeded Boolean  @default(false)
  notesForDesign         String?
  specificNotesForDesign String?
  snapshotUpdatedAt      DateTime @default(now())

  // Editable fields
  difficulty              Int?
  installerCount          Int?
  installerDays           Int?
  electricianCount        Int?
  electricianDays         Int?
  discoReco               Boolean?
  interiorAccess          Boolean?
  needsSurveyInfo         Boolean? // Flag: needs info from site surveyor → DA status "Pending Ops Changes"
  needsResurvey           Boolean? // Deprecated — retained for historical session data; no UI surface
  salesChangeRequested    Boolean? // Flag: trigger sales change → DA status "Pending Sales Changes"
  salesChangeNotes        String? // Reason for sales change → HubSpot sales_communication_reason
  opsChangeNotes          String? // Reason for ops/survey change → HubSpot ops_communication_reason
  customerNotes           String?
  customerNotesCreateTask Boolean  @default(false) // When synced, create a HubSpot task on the deal with customerNotes assigned to the PM
  operationsNotes         String?
  designNotes             String?
  conclusion              String?

  // Escalation
  escalationReason String?

  // Reviewed — marks that the team has finished reviewing this item in the meeting
  reviewed Boolean @default(false)

  // Shit Show flag — flagged for discussion in a shit show meeting
  shitShowFlagged Boolean @default(false)
  shitShowReason  String?

  // Adder checkboxes
  adderTileRoof     Boolean @default(false)
  adderMetalRoof    Boolean @default(false)
  adderFlatFoamRoof Boolean @default(false)
  adderShakeRoof    Boolean @default(false)
  adderSteepPitch   Boolean @default(false)
  adderTwoStorey    Boolean @default(false)
  adderTrenching    Boolean @default(false)
  adderGroundMount  Boolean @default(false)
  adderMpuUpgrade   Boolean @default(false)
  adderEvCharger    Boolean @default(false)
  customAdders      Json    @default("[]")

