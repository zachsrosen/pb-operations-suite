  customerName     String?
  customerEmail    String?
  customerPhone    String?
  hubspotCompanyId String?
  companyName      String?

  // Sync Metadata
  hubspotUpdatedAt DateTime?
  lastSyncedAt     DateTime       @default(now())
  syncSource       DealSyncSource
  rawProperties    Json?

  // Standard
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  syncLogs DealSyncLog[]
  notes    DealNote[]

  @@index([pipeline, stage])
  @@index([pbLocation])
  @@index([lastSyncedAt])
  @@index([hubspotOwnerId])
}

model DealSyncLog {
  id              String         @id @default(cuid())
  dealId          String?
  deal            Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  hubspotDealId   String?
  syncType        DealSyncType
  source          String
  changesDetected Json?
  dealCount       Int?
  status          DealSyncStatus
  errorMessage    String?
  durationMs      Int?
  createdAt       DateTime       @default(now())

  @@index([dealId, createdAt])
  @@index([syncType, createdAt])
  @@index([status, createdAt])
}

model DealPipelineConfig {
  id                String       @id @default(cuid())
  pipeline          DealPipeline @unique
  hubspotPipelineId String
  stages            Json
  lastSyncedAt      DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

// ===========================================
// COMMS DASHBOARD
// ===========================================

model CommsGmailToken {
  id                Int      @id @default(autoincrement())
  userId            String   @unique
  user              User     @relation("UserCommsGmailToken", fields: [userId], references: [id])
  gmailAccessToken  String
  gmailRefreshToken String
  gmailTokenExpiry  BigInt   @default(0)
  gmailEmail        String? /// Verified Gmail address from /users/me/profile at connect time
  chatEnabled       Boolean  @default(false)
  scopes            String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// OAuth credentials for shared team mailboxes (permitsdn@, permitting@,
/// interconnections@, etc.). Distinct from CommsGmailToken which is keyed
/// per-user — these are keyed per-inbox because any admin can complete
/// the OAuth consent once, and the resulting tokens serve all users who
/// read the Permit Hub / IC Hub correspondence tab. Workaround for
/// Workspace domain-wide-delegation being blocked on super-admin.
model SharedInboxCredential {
  id             Int      @id @default(autoincrement())
  inboxAddress   String   @unique /// e.g. "permitsdn@photonbrothers.com"
  accessToken    String
  refreshToken   String
  tokenExpiry    BigInt   @default(0) /// ms since epoch when access token expires
  scopes         String   @default("")
  connectedBy    String /// email of the user who completed the OAuth consent
  connectedAt    DateTime @default(now())
  lastRefreshAt  DateTime @default(now())
  lastRefreshErr String? /// non-null if latest refresh failed; cleared on success
  updatedAt      DateTime @updatedAt
}

model CommsAiMemory {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation("UserCommsAiMemory", fields: [userId], references: [id])
  kind      String
  key       String   @default("")
  data      Json
  createdAt DateTime @default(now())

  @@index([userId, kind])
  @@index([userId, kind, key])
}

model CommsUserState {
  id              Int       @id @default(autoincrement())
  userId          String    @unique
  user            User      @relation("UserCommsUserState", fields: [userId], references: [id])
  gmailHistoryId  String    @default("")
  chatLastSyncAt  DateTime?
  lastRefreshedAt DateTime?
  updatedAt       DateTime  @updatedAt
}

// ===========================================
// PRODUCT SYNC
// ===========================================

model ProductSyncRun {
  id             String    @id @default(cuid())
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  trigger        String // "cron" | "manual"
  triggeredBy    String? // user email for manual triggers
  zohoScanned    Int       @default(0)
  hubspotScanned Int       @default(0)
  zuperScanned   Int       @default(0)
  imported       Int       @default(0)
  linked         Int       @default(0)
  flagged        Int       @default(0)
  skipped        Int       @default(0)
  errors         String? // JSON array of error messages
  lockSentinel   String? // "ACTIVE" while running, null when done

  @@unique([lockSentinel], name: "uq_product_sync_active_run")
  @@index([startedAt])
}

model DealNote {
  id                String   @id @default(cuid())
  dealId            String
  deal              Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  content           String   @db.VarChar(5000)
  authorEmail       String
  authorName        String
  hubspotSyncStatus String? // PENDING | SYNCED | FAILED
  zuperSyncStatus   String? // PENDING | SYNCED | FAILED | SKIPPED
  createdAt         DateTime @default(now())

  @@index([dealId, createdAt])
}

// ===========================================
// ROLE OVERRIDES (runtime-editable via admin UI)
// ===========================================

/// Per-role capability override. One row per role at most. Null field values
/// mean "inherit the code-level default from src/lib/roles.ts defaultCapabilities".
/// Admin edits via PUT /api/admin/roles/[role]/capabilities.
///
/// See: docs/superpowers/plans/2026-04-18-role-management-ui-roadmap.md (Option B)
model RoleCapabilityOverride {
  id                     String   @id @default(cuid())
  role                   UserRole @unique
  canScheduleSurveys     Boolean?
  canScheduleInstalls    Boolean?
  canScheduleInspections Boolean?
  canSyncZuper           Boolean?
  canManageUsers         Boolean?
  canManageAvailability  Boolean?
  canEditDesign          Boolean?
  canEditPermitting      Boolean?
  canViewAllLocations    Boolean?
  canManageAdders        Boolean?
  updatedAt              DateTime @updatedAt
  updatedByEmail         String?

  @@index([role])
}

/// Per-role definition override. One row per canonical role at most.
/// The `override` column is a sparse RoleDefinitionOverridePayload JSON blob
/// (see src/lib/role-override-types.ts). Missing keys mean "inherit the
/// code default from src/lib/roles.ts"; present keys (including empty arrays)
/// mean "replace the code default with this value."
///
/// Admin edits via PUT /api/admin/roles/[role]/definition. Resolver in
/// src/lib/role-resolution.ts reads this table alongside RoleCapabilityOverride.
///
/// See: docs/superpowers/specs/2026-04-20-role-access-editor-design.md
model RoleDefinitionOverride {
  id             String   @id @default(cuid())
  role           UserRole @unique
  override       Json
  updatedAt      DateTime @updatedAt
  updatedByEmail String?

  @@index([role])
}

// ===========================================
// ON-CALL ELECTRICIAN ROTATIONS
// ===========================================

/// Pool — one per independent rotation. Current pools: California, Colorado.
model OnCallPool {
  id                String  @id @default(cuid())
  name              String  @unique
  region            String
  /// Weekday shift window (Mon-Fri). HH:mm in the pool's timezone.
  shiftStart        String
  shiftEnd          String
  /// Weekend shift window (Sat/Sun). HH:mm in the pool's timezone.
  /// Defaults set for the May 2026 trial: 8am-12pm.
  weekendShiftStart String  @default("08:00")
  weekendShiftEnd   String  @default("12:00")
  timezone          String
  startDate         String
  horizonMonths     Int     @default(3)
  /// Rotation cadence: "daily" or "weekly". New pools default to "weekly".
  /// Weekly anchors on the Sunday of startDate (Sun-Sat weeks).
  rotationUnit      String  @default("weekly")
  isActive          Boolean @default(true)

  lastPublishedAt      DateTime?
  lastPublishedBy      String?
  lastPublishedThrough String?

  icalToken String? @unique

  members      OnCallPoolMember[]
  assignments  OnCallAssignment[]
  swapRequests OnCallSwapRequest[]
  ptoRequests  OnCallPtoRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

/// Pool membership with rotation order.
model OnCallPoolMember {
  id           String     @id @default(cuid())
  poolId       String
  pool         OnCallPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  crewMemberId String
  crewMember   CrewMember @relation(fields: [crewMemberId], references: [id])
  orderIndex   Int
  isActive     Boolean    @default(true)
  addedAt      DateTime   @default(now())

  @@unique([poolId, crewMemberId])
  @@index([poolId, orderIndex])
}

/// A single day's on-call assignment. One row per (pool, date).
model OnCallAssignment {
  id                   String      @id @default(cuid())
  poolId               String
  pool                 OnCallPool  @relation(fields: [poolId], references: [id], onDelete: Cascade)
  date                 String
  crewMemberId         String
  crewMember           CrewMember  @relation(fields: [crewMemberId], references: [id])
  source               String
  originalCrewMemberId String?
  originalCrewMember   CrewMember? @relation("OriginalAssigneeSwaps", fields: [originalCrewMemberId], references: [id])
  sourceRequestId      String?
  note                 String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([poolId, date])
  @@index([crewMemberId, date])
  @@index([poolId, source])
}

/// Electrician-proposed swap. Two-party: requester gives up their day, counterparty covers; requester takes counterparty's day in return.
model OnCallSwapRequest {
  id     String     @id @default(cuid())
  poolId String
  pool   OnCallPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  requesterCrewMemberId String
  requesterCrewMember   CrewMember @relation("RequesterSwaps", fields: [requesterCrewMemberId], references: [id])
  requesterDate         String

  counterpartyCrewMemberId String
  counterpartyCrewMember   CrewMember @relation("CounterpartySwaps", fields: [counterpartyCrewMemberId], references: [id])
  counterpartyDate         String

  reason String?
  status String

  counterpartyAcceptedAt DateTime?
  reviewedByUserId       String?
  reviewedAt             DateTime?
  denialReason           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poolId, status])
  @@index([requesterCrewMemberId])
  @@index([counterpartyCrewMemberId])
}

/// Electrician-requested PTO that removes them from rotation for a date range.
model OnCallPtoRequest {
  id           String     @id @default(cuid())
  poolId       String
  pool         OnCallPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  crewMemberId String
  crewMember   CrewMember @relation(fields: [crewMemberId], references: [id])
  startDate    String
  endDate      String
  reason       String?
  status       String

  reviewedByUserId String?
  reviewedAt       DateTime?
  denialReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([poolId, status])
  @@index([crewMemberId])
}

