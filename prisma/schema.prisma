enum IdrSessionStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum IdrItemType {
  IDR
  ESCALATION
}

enum IdrSyncStatus {
  DRAFT
  SYNCED
  FAILED
}

enum IdrThreadPostStatus {
  PENDING
  POSTED
  FAILED
  SKIPPED
}

model IdrMeetingSession {
