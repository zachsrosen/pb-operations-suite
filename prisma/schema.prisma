// PB Tech Ops Suite - Database Schema
// Using Prisma with PostgreSQL (Neon)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// USER & AUTHENTICATION
// ===========================================

enum UserRole {
  ADMIN // Full access, user management, all dashboards
  EXECUTIVE // Executive — all routes except admin (renamed from OWNER)
  OWNER // Legacy — normalizes to EXECUTIVE (kept for pre-migration compat)
  MANAGER // Legacy — normalizes to PROJECT_MANAGER
  OPERATIONS // Can schedule installs/inspections, manage construction flow
  OPERATIONS_MANAGER // Operations managers — crew oversight, scheduling, availability
  SERVICE // Service team — tickets, priority queue, service scheduling, customer history
  PROJECT_MANAGER // Project managers — project tracking, scheduling, reporting
  SALES_MANAGER // Sales managers — team oversight, pipeline visibility, scheduling
  TECH_OPS // Field technicians — view schedules, self-service availability
  DESIGN // D&E suite only
  PERMIT // P&I suite (permitting portion)
  INTERCONNECT // P&I suite (interconnection portion)
  INTELLIGENCE // Intelligence suite only
  ROOFING // D&R + Roofing suite only
  MARKETING // Sales & Marketing suite only (read-only)
  DESIGNER // Legacy — normalizes to TECH_OPS
  PERMITTING // Legacy — normalizes to TECH_OPS
  VIEWER // Read-only access to all dashboards
  SALES // Only survey scheduler access (for sales team)
  ACCOUNTING // Accounting team — Accounting Suite access only
}

model User {
  id    String     @id @default(cuid())
  email String     @unique
  name  String?
  image String?
  roles UserRole[] @default([])

  // OAuth fields
  googleId String? @unique

  // Permissions - can override role defaults
  canScheduleSurveys    Boolean @default(false)
  canScheduleInstalls   Boolean @default(false)
  canSyncToZuper        Boolean @default(false)
  canManageUsers        Boolean @default(false)
  canManageAvailability Boolean @default(false)
  canManageAdders       Boolean @default(false)

  // Per-user route overrides — extras added to / subtracted from the role
  // union. Denied wins over allowed within the same user. Admin-editable via
  // /admin/users (Option D). Empty arrays mean "no per-user route tweaks".
  extraAllowedRoutes String[] @default([])
  extraDeniedRoutes  String[] @default([])

  // Location restrictions (empty = all locations)
  allowedLocations String[] @default([])

  // Admin impersonation - when set, this admin is viewing as another user
  impersonatingUserId String?

  // User preferences (JSON blob for flexible settings)
  preferences Json?

  // HubSpot owner link — explicitly linking a PB user to their HubSpot owner
  // record. Used by the My Tasks page to fetch the user's HubSpot tasks.
  // When null, the app falls back to heuristic matching on login email.
  hubspotOwnerId String?

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  activities    ActivityLog[]
  auditSessions AuditSession[]

  // Solar Surveyor relations
  solarProjects        SolarProject[]         @relation("SolarProjectCreator")
  solarProjectsUpdated SolarProject[]         @relation("SolarProjectUpdater")
  solarRevisions       SolarProjectRevision[] @relation("SolarRevisionCreator")
  solarFeedback        SolarFeedback[]        @relation("SolarFeedbackAuthor")
  solarProjectShares   SolarProjectShare[]    @relation("SolarProjectShares")
  solarPendingStates   SolarPendingState[]    @relation("SolarPendingStates")
  solarCustomEquipment SolarCustomEquipment[] @relation("SolarCustomEquipmentCreator")

  // Comms
  commsGmailToken CommsGmailToken? @relation("UserCommsGmailToken")
  commsAiMemories CommsAiMemory[]  @relation("UserCommsAiMemory")
  commsUserState  CommsUserState?  @relation("UserCommsUserState")

  // Admin Workflows (Phase 1) — user-composed workflows built on Inngest
  adminWorkflowsCreated AdminWorkflow[] @relation("AdminWorkflowCreatedBy")

  // Permit Hub
  permitHubDrafts PermitHubDraft[]

  @@index([email])
  @@index([impersonatingUserId])
}

