{"id": "1703684425", "isEnabled": true, "objectTypeId": "0-3", "flowType": "WORKFLOW", "revisionId": "25", "name": "Bot Hook | Inspection Weekly Update", "description": "Sends SMS and email updates about the Site Survey phase to customers in Colorado managed by a specific project manager, then triggers a webhook and notifies an internal user.", "uuid": "Bot Hook | Inspection Weekly Update-1703684425", "createdAt": "2025-10-10T17:21:22.979Z", "updatedAt": "2026-02-20T17:47:03.614Z", "startActionId": "2", "nextAvailableActionId": "8", "actions": [{"actionId": "1", "actionTypeVersion": 0, "actionTypeId": "0-5", "connection": {"edgeType": "STANDARD", "nextActionId": "3"}, "fields": {"property_name": "project_status", "value": {"staticValue": "This is a {{ enrolled_object.project_type }} project worth a contract value of {{ enrolled_object.amount }}. The project stage is {{ enrolled_object.dealstage }}.\n\nThe sales consultant is {{ enrolled_object.hubspot_owner_id }}. \n\nThe project manager is {{ enrolled_object.project_manager }}. \n\nThis project is based out of our {{ enrolled_object.pb_location }} office. \n\nThe address for this job is {{ enrolled_object.address_line_1 }}, {{ enrolled_object.city }}, {{ enrolled_object.state }} {{ enrolled_object.postal_code }}.\n\nThe Authority Having Jurisdiction (AHJ) is {{ fetched_objects.fetched_object_192512628.record_name }}. They take {{ fetched_objects.fetched_object_192512628.permit_turnaround_average }} days to approve permits. \n\nThe utility company for this address is {{ enrolled_object.utility_company }}\n\nThe site survey status is {{ enrolled_object.site_survey_status }}.\n\nThe design approval status is{{ enrolled_object.layout_status }}.\n\nThe design & engineering status is {{ enrolled_object.design_status }}. \n\nThe permit status is {{ enrolled_object.permitting_status }}. The permit submission date is: {{ enrolled_object.permit_submit_date }}. The permit issued date is {{ enrolled_object.permit_completion_date }}. \n\nThe interconnection application status with the utility company is {{ enrolled_object.interconnection_status }}.\n\nThe construction status is {{ enrolled_object.install_status }}. \n\nThe inspection status is {{ enrolled_object.final_inspection_status }}. ", "type": "STATIC_VALUE"}}, "type": "SINGLE_CONNECTION"}, {"actionId": "2", "actionTypeVersion": 0, "actionTypeId": "0-1", "connection": {"edgeType": "STANDARD", "nextActionId": "1"}, "fields": {"delta": "2", "time_unit": "MINUTES"}, "type": "SINGLE_CONNECTION"}, {"actionId": "3", "actionTypeVersion": 0, "actionTypeId": "0-5", "connection": {"edgeType": "STANDARD", "nextActionId": "4"}, "fields": {"property_name": "inspection_status_update___sms", "value": {"staticValue": "Hi, this is Olivia - Virtual Assistant with Photon Brothers. Weekly update: No change this week. Your project remains in the Inspection scheduling queue. We are working hard to schedule these inspections as soon as possible. We\u2019ll reach out proactively with your inspection date\u2014no need to check in weekly. If you\u2019re already scheduled, please disregard this message. Thanks for your patience!", "type": "STATIC_VALUE"}}, "type": "SINGLE_CONNECTION"}, {"actionId": "4", "actionTypeVersion": 0, "actionTypeId": "0-5", "connection": {"edgeType": "STANDARD", "nextActionId": "6"}, "fields": {"property_name": "inspection_status_update___email", "value": {"staticValue": "Hi there, this is Olivia - Virtual Assistant with Photon Brothers.\n\nThis is your weekly update, and there\u2019s no change to report this week. Your project remains in the Inspection scheduling queue. \n\nWe\u2019ll contact you as soon as your inspection is scheduled, and we\u2019ll continue sending these weekly updates even if there\u2019s no change. To help keep scheduling moving quickly, there\u2019s no need to follow up weekly\u2014we\u2019ll reach out the moment we can place you on the calendar.\n\nIf you\u2019ve already received an inspection date, please disregard this message.\n\nThank you for your patience and for choosing Photon Brothers!", "type": "STATIC_VALUE"}}, "type": "SINGLE_CONNECTION"}, {"actionId": "5", "method": "POST", "webhookUrl": "https://public.lindy.ai/api/v1/webhooks/lindy/d65c10cb-585b-490e-bac2-75be3b0d875b", "queryParams": [], "authSettings": {"secretName": "lindy_stage_change", "name": "Bearer", "location": "HEADER", "type": "AUTH_KEY"}, "connection": {"edgeType": "STANDARD", "nextActionId": "7"}, "type": "WEBHOOK"}, {"actionId": "6", "actionTypeVersion": 0, "actionTypeId": "0-1", "connection": {"edgeType": "STANDARD", "nextActionId": "5"}, "fields": {"delta": "1", "time_unit": "MINUTES"}, "type": "SINGLE_CONNECTION"}, {"actionId": "7", "actionTypeVersion": 0, "actionTypeId": "0-8", "fields": {"subject": "Bot Inspection Weekly Update Webhook Fired - {{ enrolled_object.dealname }}", "body": "<p>Bot Permit Webhook Fired:<br>{{ enrolled_object.dealname }}<br><br><br>{{ fetched_objects.fetched_object_192512632.firstname }} {{ fetched_objects.fetched_object_192512632.lastname }}</p>\n<p>{{ fetched_objects.fetched_object_192512632.phone }}</p>", "owner_properties": ["project_manager"]}, "type": "SINGLE_CONNECTION"}], "enrollmentCriteria": {"shouldReEnroll": true, "listFilterBranch": {"filterBranches": [{"filterBranches": [], "filters": [{"property": "deal_closed_won", "operation": {"operator": "IS_EQUAL_TO", "includeObjectsWithNoValueSet": false, "value": true, "operationType": "BOOL"}, "filterType": "PROPERTY"}, {"property": "closedate", "operation": {"operator": "IS_KNOWN", "includeObjectsWithNoValueSet": false, "operationType": "ALL_PROPERTY"}, "filterType": "PROPERTY"}, {"property": "pipeline", "operation": {"operator": "IS_ANY_OF", "includeObjectsWithNoValueSet": false, "values": ["6900017"], "operationType": "ENUMERATION"}, "filterType": "PROPERTY"}, {"property": "state", "operation": {"operator": "IS_ANY_OF", "includeObjectsWithNoValueSet": false, "values": ["CO"], "operationType": "ENUMERAT