{"id": "1667844515", "isEnabled": true, "objectTypeId": "0-3", "flowType": "WORKFLOW", "revisionId": "16", "name": "Bot Hook | Permit", "description": "Sends SMS and email updates about the Site Survey phase to customers in Colorado managed by a specific project manager, then triggers a webhook and notifies an internal user.", "uuid": "Bot Hook | Permit-1667844515", "createdAt": "2025-07-02T17:48:35.837Z", "updatedAt": "2026-02-20T17:52:11.864Z", "startActionId": "2", "nextAvailableActionId": "8", "actions": [{"actionId": "1", "actionTypeVersion": 0, "actionTypeId": "0-5", "connection": {"edgeType": "STANDARD", "nextActionId": "3"}, "fields": {"property_name": "project_status", "value": {"staticValue": "This is a {{ enrolled_object.project_type }} project worth a contract value of {{ enrolled_object.amount }}. The project stage is {{ enrolled_object.dealstage }}.\n\nThe sales consultant is {{ enrolled_object.hubspot_owner_id }}. \n\nThe project manager is {{ enrolled_object.project_manager }}. \n\nThis project is based out of our {{ enrolled_object.pb_location }} office. \n\nThe address for this job is {{ enrolled_object.address_line_1 }}, {{ enrolled_object.city }}, {{ enrolled_object.state }} {{ enrolled_object.postal_code }}.\n\nThe Authority Having Jurisdiction (AHJ) is {{ fetched_objects.fetched_object_151144515.record_name }}. They take {{ fetched_objects.fetched_object_151144515.permit_turnaround_average }} days to approve permits. \n\nThe utility company for this address is {{ enrolled_object.utility_company }}\n\nThe site survey status is {{ enrolled_object.site_survey_status }}.\n\nThe design approval status is{{ enrolled_object.layout_status }}.\n\nThe design & engineering status is {{ enrolled_object.design_status }}. \n\nThe permit status is {{ enrolled_object.permitting_status }}. The permit submission date is: {{ enrolled_object.permit_submit_date }}. The permit issued date is {{ enrolled_object.permit_completion_date }}. \n\nThe interconnection application status with the utility company is {{ enrolled_object.interconnection_status }}.\n\nThe construction status is {{ enrolled_object.install_status }}. \n\nThe inspection status is {{ enrolled_object.final_inspection_status }}. ", "type": "STATIC_VALUE"}}, "type": "SINGLE_CONNECTION"}, {"actionId": "2", "actionTypeVersion": 0, "actionTypeId": "0-1", "connection": {"edgeType": "STANDARD", "nextActionId": "1"}, "fields": {"delta": "2", "time_unit": "MINUTES"}, "type": "SINGLE_CONNECTION"}, {"actionId": "3", "actionTypeVersion": 0, "actionTypeId": "0-5", "connection": {"edgeType": "STANDARD", "nextActionId": "4"}, "fields": {"property_name": "permit_update___sms", "value": {"staticValue": "Hello, this is Olivia - Virtual Assistant with Photon Brothers. You\u2019re now in the Permitting & Interconnection phase, where we submit applications to your utility and local building department (AHJ). Timelines of approval can vary from days to months, depending on the jurisdiction. \n\nWe\u2019ll send weekly updates to keep you informed of your project, even if the update is just that things are still under review. We\u2019re tracking everything closely and will let you know as soon as there\u2019s progress. \n\nThanks for your patience!\n\nReply END to stop texts.", "type": "STATIC_VALUE"}}, "type": "SINGLE_CONNECTION"}, {"actionId": "4", "actionTypeVersion": 0, "actionTypeId": "0-5", "connection": {"edgeType": "STANDARD", "nextActionId": "6"}, "fields": {"property_name": "permit_update___email", "value": {"staticValue": "Hello, this is Olivia - Virtual Assistant with Photon Brothers.\n\nYou\u2019re now in the Permitting & Interconnection phase of your project\u2014this is where we submit applications to your utility and local building department (AHJ) for approval.\n\nTimelines for approval can vary quite a bit depending on your utility and jurisdiction\u2014some take just days or weeks, others can take longer.\n\nWe will be keeping you updated with weekly emails on your project status. Sometimes the update may be that things are still under review, but rest assured, we\u2019re actively monitoring your project and will let you know as soon as there\u2019s progress.\n\nWe appreciate your patience and look forward to providing updates. Please let us know if you have any questions.\n\nBest,\nPhoton Brothers", "type": "STATIC_VALUE"}}, "type": "SINGLE_CONNECTION"}, {"actionId": "5", "method": "POST", "webhookUrl": "https://public.lindy.ai/api/v1/webhooks/lindy/d65c10cb-585b-490e-bac2-75be3b0d875b", "queryParams": [], "authSettings": {"secretName": "lindy_stage_change", "name": "Bearer", "location": "HEADER", "type": "AUTH_KEY"}, "connection": {"edgeType": "STANDARD", "nextActionId": "7"}, "type": "WEBHOOK"}, {"actionId": "6", "actionTypeVersion": 0, "actionTypeId": "0-1", "connection": {"edgeType": "STANDARD", "nextActionId": "5"}, "fields": {"delta": "1", "time_unit": "MINUTES"}, "type": "SINGLE_CONNECTION"}, {"actionId": "7", "actionTypeVersion": 0, "actionTypeId": "0-8", "fields": {"subject": "Bot Permit Webhook Fired - {{ enrolled_object.dealname }}", "body": "<p>Bot Permit Webhook Fired:<br>{{ enrolled_object.dealname }}<br><br><br>{{ fetched_objects.fetched_object_151144510.firstname }} {{ fetched_objects.fetched_object_151144510.lastname }}</p>\n<p>{{ fetched_objects.fetched_object_151144510.phone }}</p>", "owner_properties": ["project_manager"]}, "type": "SINGLE_CONNECTION"}], "enrollmentCriteria": {"shouldReEnroll": false, "listFilterBranch": {"filterBranches": [{"filterBranches": [], "filters": [{"property": "deal_closed_won", "operation": {"operator": "IS_EQUAL_TO", "includeObjectsWithNoValueSet": false, "value": true, "operationType": "BOOL"}, "filterType": "PROPERTY"}, {"property": "closedate", "operation": {"operator": "IS_KNOWN", "includeObjectsWithNoValueSet": false, "operationType": "ALL_PROPERTY"}, "filterType": "PROPERTY"}, {"property": "pipeline", "operation": {"operator": "IS_ANY_OF", "includeObjectsWithNoValueSet": 