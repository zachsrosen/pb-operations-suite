# HubSpot Configuration
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HUBSPOT_PORTAL_ID=21710069
# Optional: custom HubSpot properties for construction schedule boundaries (date+time)
HUBSPOT_CONSTRUCTION_START_DATE_PROPERTY=construction_schedule_start_date
HUBSPOT_CONSTRUCTION_END_DATE_PROPERTY=construction_schedule_end_date

# HubSpot Pipeline IDs (move from hardcoded values in source)
HUBSPOT_PIPELINE_SALES=default
HUBSPOT_PIPELINE_PROJECT=6900017
HUBSPOT_PIPELINE_DNR=21997330
HUBSPOT_PIPELINE_SERVICE=23928924
HUBSPOT_PIPELINE_ROOFING=765928545

# Zuper Configuration
ZUPER_API_KEY=your-zuper-api-key
# Zuper Team UIDs (JSON format)
ZUPER_TEAM_UIDS={"Westminster":"1c23adb9-cefa-44c7-8506-804949afc56f","Centennial":"76b94bd3-e2fc-4cfe-8c2a-357b9a850b3c","Colorado Springs":"1a914a0e-b633-4f12-8ed6-3348285d6b93","San Luis Obispo":"699cec60-f9f8-4e57-b41a-bb29b1f3649c","Camarillo":"0168d963-84af-4214-ad81-d6c43cee8e65"}
# Zuper User UIDs (JSON format: { "Name": { "userUid": "...", "teamUid": "..." } })
ZUPER_USER_UIDS={"Drew Perry":{"userUid":"0ddc7e1d-62e1-49df-b89d-905a39c1e353","teamUid":"76b94bd3-e2fc-4cfe-8c2a-357b9a850b3c"},"Joe Lynch":{"userUid":"f203f99b-4aaf-488e-8e6a-8ee5e94ec217","teamUid":"1c23adb9-cefa-44c7-8506-804949afc56f"},"Derek Pomar":{"userUid":"f3bb40c0-d548-4355-ab39-6c27532a6d36","teamUid":"76b94bd3-e2fc-4cfe-8c2a-357b9a850b3c"},"Rolando":{"userUid":"a89ed2f5-222b-4b09-8bb0-14dc45c2a51b","teamUid":"1a914a0e-b633-4f12-8ed6-3348285d6b93"},"Ryszard Szymanski":{"userUid":"e043bf1d-006b-4033-a46e-3b5d06ed3d00","teamUid":"1c23adb9-cefa-44c7-8506-804949afc56f"},"Nick Scarpellino":{"userUid":"8e67159c-48fe-4fb0-acc3-b1c905ff6e95","teamUid":"699cec60-f9f8-4e57-b41a-bb29b1f3649c"}}

# Zoho Inventory Configuration (Inventory Hub sync)
ZOHO_INVENTORY_ORG_ID=123456789
# Option A: static access token (short-lived)
ZOHO_INVENTORY_ACCESS_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B (recommended): refresh token flow (automatically refreshes token)
ZOHO_INVENTORY_REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_INVENTORY_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_INVENTORY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: region-specific domains
ZOHO_INVENTORY_API_BASE_URL=https://www.zohoapis.com/inventory/v1
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
# Optional: Zoho Inventory UI base URL for deep links in product comparison
ZOHO_INVENTORY_WEB_URL=https://inventory.zoho.com/app#/items
# Optional sync mapping (JSON)
# Map Zoho item IDs/SKUs/names to PB category+brand+model
ZOHO_INVENTORY_ITEM_MAP_JSON={"382000000000001":{"category":"MODULE","brand":"REC","model":"Alpha Pure 410"}}
# Map Zoho location names/IDs to PB locations (Westminster, Centennial, Colorado Springs, San Luis Obispo, Camarillo)
ZOHO_INVENTORY_LOCATION_MAP_JSON={"Main Warehouse":"Westminster","DTC":"Centennial"}
# Optional default PB location when Zoho item has no per-location breakdown
ZOHO_INVENTORY_DEFAULT_LOCATION=Westminster

# Google OAuth Authentication (Required)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email delivery
# Preferred: Google Workspace (service account + domain-wide delegation)
GOOGLE_WORKSPACE_EMAIL_ENABLED=false
# Mailbox to impersonate when sending via Gmail API (must be a real Workspace user)
GOOGLE_EMAIL_SENDER=ops@photonbrothers.com
# Sender header shown to recipients (must be allowed as a send-as alias in Gmail if different)
EMAIL_FROM=PB Operations <ops@photonbrothers.com>
# Fallback provider (used when Google Workspace send is disabled or fails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: always BCC these recipients on assignee scheduling notifications (comma-separated)
SCHEDULING_NOTIFICATION_BCC=ops@photonbrothers.com

# Google Calendar sync
GOOGLE_CALENDAR_SYNC_ENABLED=false
# Surveyor calendar target (use "primary" for each assignee's primary calendar)
GOOGLE_SITE_SURVEY_CALENDAR_ID=primary
# Optional Nick-specific survey calendar (used when assignee email is Nick Scarpellino)
GOOGLE_SITE_SURVEY_NICK_CALENDAR_ID=your-nick-survey-calendar-id@group.calendar.google.com
# Optional shared survey calendar for CO surveys (DTC/Westy/COSP)
GOOGLE_DENVER_SITE_SURVEY_CALENDAR_ID=your-denver-survey-calendar-id@group.calendar.google.com
# Optional mailbox to impersonate for shared calendar writes (defaults to GOOGLE_EMAIL_SENDER/GOOGLE_ADMIN_EMAIL)
GOOGLE_CALENDAR_IMPERSONATION_EMAIL=ops@photonbrothers.com
# Optional install shared calendars by location
GOOGLE_INSTALL_CALENDAR_DTC_ID=your-dtc-install-calendar-id@group.calendar.google.com
GOOGLE_INSTALL_CALENDAR_WESTY_ID=your-westy-install-calendar-id@group.calendar.google.com
GOOGLE_INSTALL_CALENDAR_COSP_ID=your-cosp-install-calendar-id@group.calendar.google.com
# Optional California install shared calendars
GOOGLE_INSTALL_CALENDAR_CA_ID=your-california-install-calendar-id@group.calendar.google.com
GOOGLE_INSTALL_CALENDAR_CAMARILLO_ID=your-camarillo-install-calendar-id@group.calendar.google.com
# Backward-compat alias for COSP
GOOGLE_INSTALL_CALENDAR_PUEBLO_ID=your-cosp-install-calendar-id@group.calendar.google.com
# Optional backward-compat alias for California
GOOGLE_INSTALL_CALENDAR_CALIFORNIA_ID=your-california-install-calendar-id@group.calendar.google.com

# NextAuth Configuration
NEXTAUTH_SECRET=generate-a-random-32-char-secret-here
# Local dev default: http://localhost:3000
# Production: your canonical app URL
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=https://your-app.vercel.app

# Optional app auth hardening
# AUTH_TOKEN_SECRET is preferred for verification-token encryption; falls back to NEXTAUTH_SECRET if unset
AUTH_TOKEN_SECRET=another-random-secret
# AUTH_SALT used by legacy password endpoint; falls back to NEXTAUTH_SECRET if unset
AUTH_SALT=another-random-salt

# Allowed email domains (comma-separated for multiple)
ALLOWED_EMAIL_DOMAIN=photonbrothers.com

# API Authentication (optional - for external API access)
API_SECRET_TOKEN=your-api-secret-token

# App URL (used for redirects)
NEXT_PUBLIC_URL=https://your-app.vercel.app

# Client-side external links (used in catalog product links)
# These NEXT_PUBLIC_ vars are required for product deep-links in client components.
# Values should match the corresponding server-side vars above.
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=21710069
NEXT_PUBLIC_ZUPER_WEB_URL=https://web.zuperpro.com
NEXT_PUBLIC_ZOHO_INVENTORY_WEB_URL=https://inventory.zoho.com/app#/items
# Required for Zoho Inventory deep-links (org ID appears in URL path)
NEXT_PUBLIC_ZOHO_INVENTORY_ORG_ID=858616001

# Deployment webhook security (recommended in production)
DEPLOYMENT_WEBHOOK_SECRET=your-deployment-webhook-secret

# AI Features (anomaly detection, NL query — ADMIN/OWNER only)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Anthropic Claude (BOM extraction from planset PDFs — /api/bom/extract)
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google Gemini (AI image generation for DA photo equipment assets)
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Sentry Error Monitoring
SENTRY_AUTH_TOKEN=sntrys_your-sentry-auth-token
SENTRY_DSN=https://your-dsn@o00000.ingest.us.sentry.io/0000000
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@o00000.ingest.us.sentry.io/0000000
# Optional: protects POST /api/sentry-canary for controlled ingestion checks
SENTRY_CANARY_TOKEN=your-strong-random-token

# Travel Time (Google Maps Distance Matrix) — survey scheduling
GOOGLE_MAPS_API_KEY=           # Required for travel-time warnings on survey slots
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=  # Client-side Google Maps (restrict by HTTP referrer in Cloud Console)
TRAVEL_TIME_ENABLED=true       # "false" to disable entirely (no API calls)
TRAVEL_TIME_BUFFER_MINUTES=15  # Minutes of buffer added to drive time
TRAVEL_TIME_UNKNOWN_THRESHOLD=90  # Minutes — gaps above this skip "unknown" warnings
TRAVEL_TIME_TIGHT_THRESHOLD=0  # Minutes deficit before showing "tight" (0 = any shortfall)

# BOM Pipeline — Stage→trigger mapping (replaces DESIGN_COMPLETE_TARGET_STAGES)
# Format: stageId:type,stageId:type  (types: design_complete, ready_to_build)
# PIPELINE_STAGE_CONFIG=

# BOM Pipeline — Install-scheduled fallback (fire-and-forget pipeline when no snapshot exists)
# INSTALL_SCHEDULED_PIPELINE_FALLBACK_ENABLED=false

# NREL NSRDB API (Solar Surveyor weather data)
# Register free at https://developer.nrel.gov/signup/
NREL_API_KEY=your-nrel-api-key
NREL_EMAIL=solar@photonbrothers.com

# Solar Surveyor — allowed CORS origins (comma-separated)
# Production: https://solar.photonbrothers.com
# Dev: http://localhost:5173
SOLAR_ALLOWED_ORIGINS=http://localhost:5173

# Operational safety switches (leave false/empty in production unless intentionally enabled)
DEBUG_API_ENABLED=false
ENABLE_ADMIN_ROLE_RECOVERY=false

# IDR Meeting — HubSpot owner IDs to @mention on synced notes (comma-separated)
IDR_MEETING_MENTION_OWNER_IDS=

# ── Comms Dashboard (Gmail/Chat OAuth) ──
COMMS_GOOGLE_CLIENT_ID=         # Google OAuth client for Comms (separate from NextAuth)
COMMS_GOOGLE_CLIENT_SECRET=     # matching client secret
COMMS_TOKEN_ENCRYPTION_KEY=     # 32-byte hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── HubSpot Property custom object ──
# Note: Property sync also reuses the existing GOOGLE_MAPS_API_KEY above for
# geocoding / address normalization — no additional Maps key needed.

# Object type ID assigned by HubSpot when the Property custom object is created
# (env-driven so sandbox != prod; e.g. "2-12345678")
HUBSPOT_PROPERTY_OBJECT_TYPE=

# HubSpot labeled-association type IDs (Property ↔ Contact, Property ↔ Company)
# HubSpot assigns a distinct integer ID to every label on every association
# definition. These must be created in the "create associations with labels"
# setup step and then captured here — the sync layer reads them by name
# (see lib/property-sync.ts CONTACT_LABEL_ASSOCIATION_IDS). Each label needs
# BOTH a forward and inverse ID per HubSpot v4 convention; store both if the
# sync path needs to create either direction. Start with forward-only
# (Contact → Property).
HUBSPOT_PROPERTY_CONTACT_ASSOC_CURRENT_OWNER=
HUBSPOT_PROPERTY_CONTACT_ASSOC_PREVIOUS_OWNER=
HUBSPOT_PROPERTY_CONTACT_ASSOC_TENANT=
HUBSPOT_PROPERTY_CONTACT_ASSOC_PROPERTY_MANAGER=
HUBSPOT_PROPERTY_CONTACT_ASSOC_AUTHORIZED_CONTACT=
HUBSPOT_PROPERTY_COMPANY_ASSOC_OWNER=
HUBSPOT_PROPERTY_COMPANY_ASSOC_MANAGER=

# ── Feature flags — Property v1 ──
PROPERTY_SYNC_ENABLED=false
UI_PROPERTY_VIEWS_ENABLED=false
